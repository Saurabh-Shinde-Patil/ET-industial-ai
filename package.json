{
  "name": "et-industrial-ai-monorepo",
  "private": true,
  "version": "1.1.0",
  "description": "Unified Industrial Knowledge Intelligence - Enterprise Monorepo Root",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint . --ext .js,.jsx",
    "format": "prettier --write \"**/*.{js,jsx,json,md,yml,css}\""
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,css}": [
      "prettier --write"
    ]
  }
}
